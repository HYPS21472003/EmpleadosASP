@model IEnumerable<Empleados.Data.Entities.Departamento>

@{
    ViewData["Title"] = "Gestión de Departamentos";
}

<div class="container mt-4" style="max-width: 900px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold">Gestión de Departamentos</h2>
            <p class="text-muted mb-0">Administra las áreas operativas de la empresa.</p>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4" style="width: 15%;">ID</th>
                            <th style="width: 60%;">Nombre del Departamento</th>
                            <th class="text-center pe-4" style="width: 25%;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var depto in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-secondary">#@depto.Id</td>
                                <td class="fw-bold text-dark">@depto.Nombre</td>
                                <td class="text-center pe-4">
                                    <form asp-action="Delete" asp-route-id="@depto.Id" method="post" onsubmit="return confirm('¿Seguro que deseas eliminar este departamento?');" style="display:inline;">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash-fill me-1"></i> Eliminar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>