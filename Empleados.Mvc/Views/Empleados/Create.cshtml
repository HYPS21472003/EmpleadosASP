@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model Empleados.Mvc.Models.EmpleadoUpsertViewModel

@{
    ViewData["Title"] = "Registrar Nuevo Empleado";
}

<div class="container mt-4" style="max-width: 850px;">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-primary text-white py-3">
            <h4 class="mb-0 fw-bold"><i class="bi bi-person-plus-fill me-2"></i>Registrar Nuevo Empleado</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Nombre" class="form-label small fw-bold text-secondary">Nombre</label>
                        <input asp-for="Nombre" class="form-control" placeholder="Ej. Juan" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Apellido" class="form-label small fw-bold text-secondary">Apellido</label>
                        <input asp-for="Apellido" class="form-control" placeholder="Ej. Pérez" />
                        <span asp-validation-for="Apellido" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Puesto" class="form-label small fw-bold text-secondary">Puesto o Cargo</label>
                        <input asp-for="Puesto" class="form-control" placeholder="Ej. Desarrollador" />
                        <span asp-validation-for="Puesto" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Salario" class="form-label small fw-bold text-secondary">Salario Mensual (RD$)</label>
                        <input asp-for="Salario" type="number" step="0.01" class="form-control" placeholder="0.00" />
                        <span asp-validation-for="Salario" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CorreoElectronico" class="form-label small fw-bold text-secondary">Correo Electrónico</label>
                        <input asp-for="CorreoElectronico" type="email" class="form-control" placeholder="juan@sistema.com" />
                        <span asp-validation-for="CorreoElectronico" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Telefono" class="form-label small fw-bold text-secondary">Teléfono de Contacto</label>
                        <input asp-for="Telefono" class="form-control" placeholder="809-555-5555" />
                        <span asp-validation-for="Telefono" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Direccion" class="form-label small fw-bold text-secondary">Dirección de Residencia</label>
                        <input asp-for="Direccion" class="form-control" placeholder="Calle, No. Casa, Sector" />
                        <span asp-validation-for="Direccion" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="DepartamentoId" class="form-label small fw-bold text-secondary">Departamento Asignado</label>
                        <select asp-for="DepartamentoId" class="form-select">
                            <option value="">-- Seleccione un Departamento --</option>
                            <option value="1">Tecnología de la Información</option>
                            <option value="2">Recursos Humanos</option>
                            <option value="3">Operaciones y Logística</option>
                        </select>
                        <span asp-validation-for="DepartamentoId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-bold text-secondary">Fotografía del Empleado</label>
                        <input type="file" name="FotoArchivo" class="form-control" accept="image/*" />
                        <div class="form-text small text-muted">Formatos admitidos: JPG, PNG, JPEG. Max 2MB.</div>
                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-end mt-4 pt-3 border-top">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-save-fill me-2"></i>Guardar Expediente
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}