@model Empleados.Mvc.Models.EmpleadoUpsertViewModel

@{
    ViewData["Title"] = "Editar Expediente de Empleado";
}

<div class="container mt-4" style="max-width: 800px;">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-dark text-white py-3">
            <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i> Editar Expediente del Empleado</h4>
        </div>
        <div class="card-body p-4">

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger shadow-sm border-0 mb-4" role="alert">
                    <div asp-validation-summary="All" class="mb-0 small fw-bold"></div>
                </div>
            }

            <form asp-action="Edit" method="post" enctype="multipart/form-data" class="row g-3">
                <input type="hidden" asp-for="Id" />

                <div class="col-md-6">
                    <label class="form-label small fw-bold text-secondary">Nombre</label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ej. Juan" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-bold text-secondary">Apellido</label>
                    <input asp-for="Apellido" class="form-control" placeholder="Ej. Pérez" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-bold text-secondary">Puesto / Cargo</label>
                    <input asp-for="Puesto" class="form-control" placeholder="Ej. Gerente" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-bold text-secondary">Salario Mensual (RD$)</label>
                    <input asp-for="Salario" type="number" step="0.01" class="form-control" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-bold text-secondary">Correo Electrónico</label>
                    <input asp-for="CorreoElectronico" type="email" class="form-control" placeholder="correo@empresa.com" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-bold text-secondary">Teléfono de Contacto</label>
                    <input asp-for="Telefono" class="form-control" placeholder="809-555-0100" required />
                </div>

                <div class="col-md-10">
                    <label class="form-label small fw-bold text-secondary">Dirección Residencial</label>
                    <input asp-for="Direccion" class="form-control" required />
                </div>

                <div class="col-md-2">
                    <label class="form-label small fw-bold text-secondary">Dept. ID</label>
                    <input asp-for="DepartamentoId" type="number" class="form-control" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-bold text-secondary">Fecha de Nacimiento</label>
                    <input asp-for="FechaNacimiento" type="date" class="form-control" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-bold text-secondary">Fecha de Contratación</label>
                    <input asp-for="ContactacionFecha" type="date" class="form-control" required />
                </div>

                <div class="col-12 mt-4">
                    <div class="p-3 bg-light rounded border">
                        <label class="form-label small fw-bold text-dark"><i class="bi bi-camera-fill me-1"></i> Actualizar Fotografía Física del Servidor</label>
                        <input type="file" name="FotoArchivo" class="form-control" accept=".jpg,.jpeg,.png" />
                        <span class="text-muted small d-block mt-1">Formatos admitidos: .jpg, .jpeg, .png. La imagen se alojará en el almacenamiento persistente de la API.</span>
                    </div>
                </div>

                <div class="col-12 d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-dark px-4 fw-bold">
                        <i class="bi bi-save-fill me-1"></i> Guardar Cambios
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>