@model Empleados.Mvc.Models.LoginViewModel

@{
    Layout = null; // No usamos el menú general en el login
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión - Control de Empleados</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #0d6efd 0%, #0a4ebd 100%);
            height: 100vh;
        }
        .card-login {
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center">

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card card-login bg-white p-4">
                    <div class="text-center mb-4">
                        <h3 class="text-primary fw-bold">ControlEmpleados</h3>
                        <p class="text-muted">Sistema de Control de Empleados</p>
                    </div>

                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Usuario" class="form-label text-secondary small fw-bold">Usuario</label>
                            <input asp-for="Usuario" class="form-control" placeholder="Ej. admin" autocomplete="off" />
                            <span asp-validation-for="Usuario" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label text-secondary small fw-bold">Contraseña</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2 mt-2 fw-bold">
                            Ingresar al Sistema
                        </button>
                    </form>

                    
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>